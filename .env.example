# Stock Data Server Configuration
# Copy this file to .env and fill in your API keys

# === Tushare Pro API (Priority 0 for A-share) ===
# Get your token from: https://tushare.pro/user/token
TUSHARE_TOKEN=

# === Baostock (Priority 1 for A-share, no token required) ===
# No configuration needed

# === Akshare (Priority 2 for A/HK stocks) ===
# No configuration needed

# === Yfinance (Priority 3 for US stocks) ===
# No configuration needed

# === Zhitu (Priority 99 for A-share realtime, last resort) ===
# Get your token from: https://www.zhituapi.com/
ZHITU_TOKEN=

# === Myquant (掘金量化) (Priority 1 for A-share backup, requires token) ===
# Get your token from: https://www.myquant.cn/
MYQUANT_TOKEN=

# === Myquant Priority Override ===
# Default: 1 (right after Tushare=0, alongside Baostock=1)
# MYQUANT_PRIORITY=1

# === Baidu Qianfan (Priority 7 for news search backup, requires API Key) ===
# Get your API Key from: https://console.bce.baidu.com/qianfan/ais/console/apiKey
# Format: bce-v3/ALTAK-xxx/xxx
BAIDU_API_KEY=
# BAIDU_PRIORITY=7
# Restrict Baidu news search to specific domains (comma-separated).
# Default: the canonical news subdomain of each of the 3 authoritative
# Chinese financial-news sources (东方财富 / 财联社 / 同花顺):
#   finance.eastmoney.com,www.cls.cn,news.10jqka.com.cn
# Each entry is the SPECIFIC news subdomain (not the parent domain),
# which keeps non-news entry points (guba / quote / fund / m-cls) out
# of the response by construction. Matched as a host suffix, so deeper
# subdomains (e.g. news.finance.eastmoney.com) are also allowed.
# BaiduFetcher is the NEWS_SEARCH backup for EastMoneyFetcher.search_news;
# to use the older parent-domain style, set:
# BAIDU_NEWS_DOMAINS=eastmoney.com,cls.cn,10jqka.com.cn
# Empty string disables the filter (returns all results upstream allows).
# BAIDU_NEWS_DOMAINS=finance.eastmoney.com,www.cls.cn,news.10jqka.com.cn
# Explicit denylist (comma-separated exact hosts). Sent upstream inside
# the `block_websites` body field and mirrored client-side. Default
# excludes sub-par eastmoney.com entry points (emwap/quote/guba) plus
# all known mobile subdomains of the 3 whitelisted sources. Empty string
# disables.
# BAIDU_NEWS_BLOCKED_DOMAINS=emwap.eastmoney.com,emdatah5.eastmoney.com,quote.eastmoney.com,guba.eastmoney.com,mguba.eastmoney.com,fund.eastmoney.com,data.eastmoney.com,m.eastmoney.com,wap.eastmoney.com,mobile.eastmoney.com,mb.eastmoney.com,m.cls.cn,wap.cls.cn,mobile.cls.cn,mb.cls.cn,m.10jqka.com.cn,wap.10jqka.com.cn,mobile.10jqka.com.cn,mb.10jqka.com.cn
# Mobile-subdomain safety-net filter (comma-separated host prefixes,
# client-side only). Drops records whose host starts with one of these —
# a defense against future mobile subdomains that may not be in the
# explicit denylist above. Empty string disables.
# BAIDU_NEWS_MOBILE_PREFIXES=m.,wap.,mobile.,mb.

# === Server Configuration ===
SERVER_PORT=8888
SERVER_HOST=127.0.0.1

# === Data Source Priority Override ===
# Comma-separated list of sources, first available is used
# Values: tushare, baostock, akshare, yfinance
# Default order is determined by priority attribute in each fetcher

# === Feature Flags ===
ENABLE_REALTIME_QUOTE=true

# === API Response Cache (in-process, per-process TTL buckets) ===
ENABLE_API_CACHE=true
CACHE_TTL_QUOTE=60           # Realtime quote cache TTL in seconds
CACHE_TTL_HISTORY_DAILY=300    # Daily K-line cache TTL in seconds (5 min)
CACHE_TTL_HISTORY_WEEKLY=3600  # Weekly K-line cache TTL in seconds (1 hour)
CACHE_TTL_HISTORY_MONTHLY=7200 # Monthly K-line cache TTL in seconds (2 hours)
CACHE_TTL_STOCK_INFO=3600      # Stock-info (公司画像) cache TTL in seconds (1 hour)

# === Persistence (cross-process SQLite on-disk store) ===
# Path to the SQLite file. Default: <repo>/stock_data/stock_cache.db
STOCK_CACHE_DB_PATH=

# Startup behavior for the persistence layer.
#   true  -> DROP and recreate all persistence tables on boot
#            (use during dev to wipe stale metadata).
#   false -> idempotent CREATE IF NOT EXISTS only (default).
# Any other value is treated as false. WARNING: setting this to true will
# delete all cached stock lists, board metadata, trade calendar, and
# ZT/DT/ZBGC pool history.
STOCK_DB_INIT=false
