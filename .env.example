# Stock Data Server Configuration
# Copy this file to .env and fill in your API keys

# === Tushare Pro API (Priority 0 for A-share) ===
# Get your token from: https://tushare.pro/user/token
TUSHARE_TOKEN=

# === Baostock (Priority 1 for A-share, no token required) ===
# No configuration needed

# === Akshare (Priority 2 for A/HK stocks) ===
# No configuration needed

# === Yfinance (Priority 3 for US stocks) ===
# No configuration needed

# === Zhitu (Priority 99 for A-share realtime, last resort) ===
# Get your token from: https://www.zhituapi.com/
ZHITU_TOKEN=

# === Myquant (掘金量化) (Priority 1 for A-share backup, requires token) ===
# Get your token from: https://www.myquant.cn/
MYQUANT_TOKEN=

# === Myquant Priority Override ===
# Default: 1 (right after Tushare=0, alongside Baostock=1)
# MYQUANT_PRIORITY=1

# === Server Configuration ===
SERVER_PORT=8888
SERVER_HOST=0.0.0.0

# === Data Source Priority Override ===
# Comma-separated list of sources, first available is used
# Values: tushare, baostock, akshare, yfinance
# Default order is determined by priority attribute in each fetcher

# === Feature Flags ===
ENABLE_REALTIME_QUOTE=true

# === API Response Cache (in-process, per-process TTL buckets) ===
ENABLE_API_CACHE=true
CACHE_TTL_QUOTE=60           # Realtime quote cache TTL in seconds
CACHE_TTL_HISTORY_DAILY=300    # Daily K-line cache TTL in seconds (5 min)
CACHE_TTL_HISTORY_WEEKLY=3600  # Weekly K-line cache TTL in seconds (1 hour)
CACHE_TTL_HISTORY_MONTHLY=7200 # Monthly K-line cache TTL in seconds (2 hours)

# === Persistence (cross-process SQLite on-disk store) ===
# Path to the SQLite file. Default: <repo>/stock_data/stock_cache.db
STOCK_CACHE_DB_PATH=

# Startup behavior for the persistence layer.
#   true  -> DROP and recreate all persistence tables on boot
#            (use during dev to wipe stale metadata).
#   false -> idempotent CREATE IF NOT EXISTS only (default).
# Any other value is treated as false. WARNING: setting this to true will
# delete all cached stock lists, board metadata, trade calendar, and
# ZT/DT/ZBGC pool history.
STOCK_DB_INIT=false
